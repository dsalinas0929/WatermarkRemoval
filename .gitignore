# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
build/
dist/
*.egg-info/
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage
.pytest_cache/
.coverage
coverage.xml
htmlcov/

# MyPy
.mypy_cache/

# Pyre
.pyre/

# Jupyter Notebook checkpoints
.ipynb_checkpoints/

# VS Code
.vscode/

# JetBrains
.idea/
*.iml

# macOS
.DS_Store

# Logs
logs/
*.log

# Temporary files
*.tmp
*.temp
temp_*.mp4

# ffmpeg/processing artifacts
*.ts

# Model weights and large binaries (avoid accidentally committing heavy checkpoints)
*.pt
*.pth
*.ckpt
weights/
models/

# Project-specific generated folders (keep some local/large artifacts ignored)
# Note: dataset/, frames/, input_videos/, output_videos/, runs/, and samples/
# are intentionally NOT ignored so empty folders (with .gitkeep) can be tracked.
_videos/
work_frames/
POC/

# Track only the parent folders via .gitkeep; ignore any other files inside these dirs
# (this keeps the empty directories in git while preventing large/generated files from
# showing as untracked or being accidentally committed)
dataset/*
!dataset/.gitkeep
dataset/train/*
!dataset/train/.gitkeep
dataset/valid/*
!dataset/valid/.gitkeep
dataset/test/*
!dataset/test/.gitkeep

frames/*
!frames/.gitkeep

input_videos/*
!input_videos/.gitkeep

output_videos/*
!output_videos/.gitkeep

runs/*
!runs/.gitkeep

samples/*
!samples/.gitkeep

# Local inpainting wrapper artifacts (if used for experimentation)
simple-lama-inpainting/

# Secrets and environment files
.env
.env.*
secret.*
credentials

# OS or editor swap files
*.swp
*.swo
*~

# Notebook checkpoints and outputs
inpainted.png
*.psd

# Misc
venv/
